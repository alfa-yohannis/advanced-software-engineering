graph g {
  resource src uri="in.mp4" {
    port out OUT
  }

  transcoder enc backend=FFMPEG command="ffmpeg" replicas=1 videoCodec="h264" audioCodec="aac" container="mp4" bitrate=1000 {
    port in IN
    port out OUT
  }

  resource dst uri="out.mp4" {
    port in IN
  }

  edge e1 from src.out to enc.in
  edge e2 from enc.out to dst.in
}
